{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YumeFrame",
  "version": "0.1.0",
  "identifier": "dev.yumeo.yumeframe",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "YumeFrame",
        "width": 1480,
        "height": 720,
        "alwaysOnTop": false
      },
      {
        "label": "relic-overlay",
        "title": "YumeFrame Overlay",
        "url": "overlay.html",
        "width": 800,
        "height": 600,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "fullscreen": true,
        "visible": false,
        "focus": false,
        "shadow": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "tessdata/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
